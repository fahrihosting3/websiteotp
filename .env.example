# GitHub Integration for User Database
# Get your token from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Your GitHub username
GITHUB_OWNER=your_github_username

# Repository name where user data will be stored
GITHUB_REPO=ruma-otp-users

# RumahOTP API Configuration (Optional - for balance checking)
NEXT_PUBLIC_RUMAHOTP_API_KEY=your_rumahotp_api_key_here
